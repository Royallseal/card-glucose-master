# ========== 行尾符统一 ==========
# 所有文本文件默认使用 LF（Unity 内部统一使用 LF）
* text=auto eol=lf

# ========== Unity 文本文件（强制 LF）==========
# Unity 场景和预制体
*.unity text eol=lf
*.prefab text eol=lf

# Unity 资源文件（YAML 格式）
*.asset text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.playable text eol=lf
*.mask text eol=lf
*.brush text eol=lf
*.flare text eol=lf
*.fontsettings text eol=lf
*.guiskin text eol=lf
*.preset text eol=lf
*.spriteatlas text eol=lf
*.spritelib text eol=lf
*.mixer text eol=lf

# C# 脚本
*.cs text eol=lf diff=csharp

# Shader 文件
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.glslinc text eol=lf

# 计算着色器
*.compute text eol=lf

# 2D 工具链文本文件
*.svg text eol=lf
*.tps text eol=lf
*.tpsheet text eol=lf

# 配置文件
*.json text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Web 相关
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf

